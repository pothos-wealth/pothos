# ═══════════════════════════════════════════════════════════════════════════════
# Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Auto-generated by ./scripts/setup.sh — never commit to Git

# ─── Backend ──────────────────────────────────────────────────────────────────

# REQUIRED: Session secret for signing session cookies (32+ random bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-32-byte-random-secret-here

# Session expiry in days
SESSION_TTL_DAYS=7

# Rate limits (requests per minute)
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_MAX=10

# Backend port
PORT=3001

# Node environment (development or production)
NODE_ENV=development

# Database URL
DATABASE_URL=./data/pothos.db

# Optional: LLM provider for email parsing
# Supported: openai (default), anthropic, custom
LLM_PROVIDER=openai
LLM_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Public API URL (used by browser to call backend)
# Development: http://localhost:3001
# Production: https://yourdomain.com (must have schema and domain)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Domain & SSL ─────────────────────────────────────────────────────────────

# Domain name (used for nginx SSL certificate)
# Development: pothos.test.com
# Production: your actual domain
DOMAIN=pothos.test.com

# Email for Let's Encrypt certificate notifications (renewal reminders, etc.)
# Optional if bootstrapping SSL, but recommended
EMAIL=your-email@example.com
