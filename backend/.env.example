# ═══════════════════════════════════════════════════════════════════════════════
# Pothos Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values.
# Never commit .env to Git.

# ─── Required ─────────────────────────────────────────────────────────────────

# Session secret for signing session cookies (32+ random bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-32-byte-random-secret-here

# 32-byte hex string — encrypts IMAP App Passwords and LLM API keys at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-random-encryption-key-here

# ─── Superadmin ───────────────────────────────────────────────────────────────

# Email of the user to promote to superadmin on startup (idempotent).
# The user must already exist (sign up first, then set this and restart).
SUPERADMIN_EMAIL=

# ─── Registration ─────────────────────────────────────────────────────────────

# Invite code required to create an account. Leave empty for open registration.
# When set, the sign-up page shows an invite code field and the backend
# rejects any registration that does not supply the exact code.
# Visible (with copy button) in the superadmin panel at /admin.
REGISTRATION_CODE=

# ─── Database ─────────────────────────────────────────────────────────────────

DATABASE_URL=./data/pothos.db

# ─── Server ───────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# Session lifetime in days. Default: 7.
SESSION_TTL_DAYS=7

# ─── Rate Limits (requests per minute) ────────────────────────────────────────

RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_LOGIN_MAX=10

# ─── Email Ingestion ──────────────────────────────────────────────────────────

# Cron schedule for IMAP polling. Default: every 15 minutes.
# Examples: "0 */2 * * *" (every 2h), "0 9 * * *" (daily at 9am)
IMAP_POLL_CRON=*/15 * * * *

# Max simultaneous IMAP connections per poll cycle. Default: 10.
IMAP_POLL_CONCURRENCY=10

# Cron schedule for maintenance tasks (inbox cleanup, etc). Default: daily at 3am.
# Examples: "0 */6 * * *" (every 6h), "0 2 * * *" (daily at 2am)
MAINTENANCE_CRON=0 3 * * *
